{
  "_version": "1.65.0",
  "sap.app": {
    "id": "centro.medico.paciente.asistente",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {}
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "rootView": {
      "viewName": "centro.medico.paciente.asistente.view.Chat",
      "type": "XML",
      "id": "chatView",
      "async": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "centro.medico.paciente.asistente.i18n.i18n"
        }
      }
    }
  }
}
