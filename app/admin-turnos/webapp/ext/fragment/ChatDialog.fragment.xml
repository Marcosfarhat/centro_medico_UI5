<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
>
  <Dialog id="chatDialog" title="Asistente de Turnos" contentWidth="28rem" contentHeight="30rem" resizable="true">
    <content>
      <List id="chatList" items="{chat>/messages}" showSeparators="None" noDataText="Escribile algo al asistente para empezar">
        <CustomListItem>
          <VBox class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop">
            <Text text="{chat>autor}" class="sapUiTinyMarginBottom" />
            <Text text="{chat>texto}" wrapping="true" />
          </VBox>
        </CustomListItem>
      </List>
    </content>
    <footer>
      <Toolbar>
        <Input id="chatInput" placeholder="Escribí tu mensaje..." width="100%" submit="onEnviarMensajeChat" />
        <Button text="Enviar" type="Emphasized" press="onEnviarMensajeChat" />
      </Toolbar>
    </footer>
    <endButton>
      <Button text="Cerrar" press="onCerrarChat" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
